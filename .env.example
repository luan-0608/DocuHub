# Copy file nay thanh .env roi doi gia tri (file .env da duoc gitignore).
# Khong co .env he thong van chay voi gia tri dev mac dinh — rieng nhom AI
# (EMBEDDING_*/LLM_*) phai dien key thi tinh nang chat/tom tat/lap chi muc moi dung duoc.

# --- Bao mat (production PHAI doi het) ---
# JWT secret: chuoi ngau nhien >= 32 byte, ma hoa Base64
JWT_SECRET=ZGVmYXVsdC1kb2N1aHViLXNlY3JldC1jaGFuZ2UtbWUtMzJieXRlcyE=
# Token cac service dung de goi API noi bo /internal/** cua nhau
INTERNAL_TOKEN=docuhub-internal-dev-token
# Mat khau root MySQL (ca 3 database)
DB_PASS=docuhub
# RabbitMQ
RABBITMQ_USER=docuhub
RABBITMQ_PASS=docuhub

# --- Tai khoan admin seed khi user-service khoi dong ---
ADMIN_EMAIL=admin@docuhub.vn
ADMIN_PASSWORD=admin123

# --- SMTP gui email dat lai mat khau (user-service, tuy chon) ---
# Mac dinh dung Gmail: SMTP_HOST=smtp.gmail.com, SMTP_PORT=587 (khong can khai bao lai).
# Dien email Gmail vao SMTP_USER va App Password (16 ky tu, tao tai
# https://myaccount.google.com/apppasswords, can bat xac minh 2 buoc) vao SMTP_PASS.
# De trong thi he thong van chay nhung khong gui duoc email reset password.
SMTP_USER=
SMTP_PASS=

# --- Luu tru file cua document-service ---
# local      = luu vao volume Docker (mac dinh, khong can gi them)
# cloudinary = day file len Cloudinary; phai dien CLOUDINARY_URL ben duoi
STORAGE_PROVIDER=local
# Lay o Dashboard Cloudinary (muc API Keys / "API environment variable"),
# dang: cloudinary://api_key:api_secret@cloud_name
CLOUDINARY_URL=

# --- AI cho chat-service (BAT BUOC dien de dung tinh nang AI) ---
# Dung bat ky endpoint tuong thich chuan OpenAI: OpenAI that (https://api.openai.com/v1),
# hoac dich vu ben thu 3 / proxy tu dung — doi *_BASE_URL va *_MODEL tuong ung.
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_MODEL=text-embedding-3-large
# LLM_PROVIDER: openai (chuan OpenAI / ben thu 3 tuong thich) hoac gemini
LLM_PROVIDER=openai
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_CHAT_MODEL=gpt-4o-mini
